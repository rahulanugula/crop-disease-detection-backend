hs_err_pid*

# Eclipse
.metadata
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.settings/
.loadpath
.recommenders

# External tool builders
.externalToolBuilders/

# Locally stored "Eclipse launch configurations"
*.launch

# PyDev specific (if any python scripts are present)
*.pydevproject

# CDT-specific (if any C++ stuff is present)
.cproject

# JDT-specific (if any Java stuff is present)
.classpath

# Maven
.factorypath
.project

# IntelliJ IDEA
.idea
*.iws
*.iml
*.ipr

