target/
# Maven wrapper (Needed for Docker builds)
!mvnw
!mvnw.cmd
!.mvn/wrapper/maven-wrapper.properties

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

